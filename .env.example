# --- Supabase API (браузер + Server Actions, PostgREST) ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Публичный URL приложения (redirect после восстановления пароля)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Только сервер (Admin API — создание/удаление пользователей)
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres (CLI, миграции, psql) — НЕ подставлять в NEXT_PUBLIC_* ---
# Project Settings → Database → Connection string

# Transaction pooler, порт 6543 (рекомендуется для supabase db push / serverless)
DATABASE_POOLER_URL=postgresql://postgres.YOUR_PROJECT_REF:[DB_PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres

# Прямое подключение, порт 5432 (опционально)
# DATABASE_URL=postgresql://postgres:[DB_PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Supabase CLI использует эту переменную при db push / db pull
SUPABASE_DB_URL=
